{
  "name": "polyseek",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "db:test:up": "docker compose --env-file .env.test up -d test-db",
    "db:test:migrate": "dotenv -e .env.test -- npx prisma migrate deploy",
    "test:e2e:run": "cross-env NEXT_PUBLIC_SENTRY_ENABLED=false dotenv -e .env.test -- npx playwright test --trace on",
    "test:e2e": "cross-env NEXT_PUBLIC_SENTRY_ENABLED=false dotenv -e .env.test -- npm run build && npm run db:test:up && npm run db:test:migrate && dotenv -e .env.test -- npx prisma db seed && npm run test:e2e:run",
    "compare-queries": "tsx src/scripts/compare-queries.ts",
    "db:promo:up": "docker compose --env-file .env.promotion up -d promotion-db",
    "db:promo:migrate": "dotenv -e .env.promotion -- npx prisma migrate deploy",
    "db:promo:seed": "dotenv -e .env.promotion -- npx prisma db seed",
    "dev:promotion": "dotenv -e .env.promotion -- next dev -p 3001",
    "promo:add-shop": "dotenv -e .env.promotion -- tsx src/scripts/add-promotion-shop.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@heroicons/react": "^2.2.0",
    "@next/third-parties": "^16.1.6",
    "@notionhq/client": "^5.11.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.40.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "driver.js": "^1.4.0",
    "embla-carousel-react": "^8.6.0",
    "he": "^1.2.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.576.0",
    "mermaid": "^11.12.3",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.27",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "p-queue": "^9.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "robots-parser": "^3.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/he": "^1.2.3",
    "@types/jsdom": "^28",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28",
    "playwright": "^1.58.2",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
